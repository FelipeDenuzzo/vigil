rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: verifica se o usuário autenticado é admin ──────────────────────
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── users ──────────────────────────────────────────────────────────────────
    // Usuário lê/cria o próprio documento. Admin lê e atualiza qualquer um.
    match /users/{uid} {
      // Leitura: próprio usuário ou admin
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isAdmin());

      // Criação: apenas o próprio usuário, com campos controlados
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.accessStatus == 'pending'
                    && request.resource.data.role == 'user';

      // Atualização: apenas admin (aprovar, bloquear, promover)
      allow update: if isAdmin();

      // ← ADICIONADO: usuário grava apenas baseline e onboardingCompleted no próprio doc
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['baseline', 'onboardingCompleted']);
    }

    // ── sessions ───────────────────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.uid;

      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
    }

    // ── sessionReports ────────────────────────────────────────────────────────
    match /sessionReports/{sessionId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.uid;

      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
    }

    // ── consent ───────────────────────────────────────────────────────────────
    match /consent/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Bloqueia qualquer outro caminho não mapeado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
